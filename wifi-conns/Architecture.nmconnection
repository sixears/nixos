[connection]
id=Architecture
type=wifi

[wifi]
mode=infrastructure
ssid=Architecture

[wifi-security]
auth-alg=open
key-mgmt=wpa-psk

[ipv4]
address1=$IP4ADDR/24
dns=192.168.0.24;192.168.0.7;
dns-options=edns0;
dns-search=sixears.co.uk;
gateway=192.168.0.1
method=manual

[ipv6]
addr-gen-mode=stable-privacy
method=auto

[proxy]
